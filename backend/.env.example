# ─────────────────────────────────────────────────────────────
# Configuration du backend Lynda (Node.js — server.js)
# Copiez ce fichier en ".env" et renseignez vos clés.
# ─────────────────────────────────────────────────────────────

# Clés API Groq (IA) — https://console.groq.com
# Au moins une est requise pour que /api/chat fonctionne.
GROQ_KEY=gsk_votre_cle_groq_1
GROQ_KEY_2=gsk_votre_cle_groq_2

# Clé OpenRouter (repli gratuit si Groq est en quota)
OPENROUTER_KEY=sk-or-votre_cle_openrouter

# ── Recherche d'IMAGES ───────────────────────────────────────
# Toutes les images passent par Getty Images en priorité.
# Si GETTY_KEY est absent ou l'API échoue, repli sur Pexels puis Wikipedia.
# Obtenir une clé : https://developer.gettyimages.com/
GETTY_KEY=

# Repli 1 : Pexels (https://www.pexels.com/api/)
PEXELS_KEY=

# Repli 2 : Unsplash (https://unsplash.com/developers)
UNSPLASH_KEY=
